---
interface Props {
  term: string;
}

const { term } = Astro.props;
---

<div class="comp-definicion" data-component="definicion" role="note" aria-label={`Definición: ${term}`}>
  <div class="comp-badge comp-badge-blue">Definición</div>
  <div class="comp-body">
    <strong class="comp-term">{term}</strong>: <slot />
  </div>
</div>

<style>
  .comp-definicion {
    border-left: 4px solid var(--sl-color-blue-600);
    background: var(--sl-color-blue-50);
    padding: 1em 1.25em;
    margin: 1.5em 0;
    border-radius: 0 6px 6px 0;
    font-size: 0.95em;
  }

  :root[data-theme="dark"] .comp-definicion,
  :global([data-theme="dark"]) .comp-definicion {
    background: var(--sl-color-blue-950);
    border-left-color: var(--sl-color-blue-400);
  }

  .comp-badge {
    display: inline-block;
    font-size: 0.75em;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.15em 0.6em;
    border-radius: 3px;
    margin-bottom: 0.5em;
  }

  .comp-badge-blue {
    background: var(--sl-color-blue-200);
    color: var(--sl-color-blue-900);
  }

  :root[data-theme="dark"] .comp-badge-blue,
  :global([data-theme="dark"]) .comp-badge-blue {
    background: var(--sl-color-blue-700);
    color: var(--sl-color-blue-100);
  }

  .comp-body {
    color: var(--sl-color-text);
  }

  .comp-term {
    font-weight: 700;
    color: var(--sl-color-blue-800);
  }

  :root[data-theme="dark"] .comp-term,
  :global([data-theme="dark"]) .comp-term {
    color: var(--sl-color-blue-300);
  }

  @media (max-width: 720px) {
    .comp-definicion {
      margin-left: 0;
      margin-right: 0;
      border-radius: 0 4px 4px 0;
    }
  }

  @media print {
    .comp-definicion {
      background: none;
      border-left-width: 2px;
      padding: 0.5em 0.75em;
    }
  }
</style>
