---
---

<div class="comp-advertencia" data-component="advertencia" role="alert" aria-label="Advertencia">
  <div class="comp-advertencia-icon" aria-hidden="true">⚠️</div>
  <div class="comp-body">
    <slot />
  </div>
</div>

<style>
  .comp-advertencia {
    border: 1px solid var(--sl-color-orange-400);
    border-left: 4px solid var(--sl-color-orange-500);
    background: var(--sl-color-orange-50);
    padding: 1em 1.25em;
    margin: 1.5em 0;
    border-radius: 0 8px 8px 0;
    display: flex;
    gap: 0.75em;
    align-items: flex-start;
  }

  :root[data-theme="dark"] .comp-advertencia,
  :global([data-theme="dark"]) .comp-advertencia {
    background: var(--sl-color-orange-950);
    border-color: var(--sl-color-orange-600);
    border-left-color: var(--sl-color-orange-400);
  }

  .comp-advertencia-icon {
    font-size: 1.2em;
    flex-shrink: 0;
    margin-top: 0.1em;
  }

  .comp-body {
    color: var(--sl-color-orange-900);
    font-size: 0.93em;
    line-height: 1.6;
  }

  :root[data-theme="dark"] .comp-body,
  :global([data-theme="dark"]) .comp-body {
    color: var(--sl-color-orange-200);
  }

  @media (max-width: 720px) {
    .comp-advertencia {
      margin-left: 0;
      margin-right: 0;
      border-radius: 0 4px 4px 0;
    }
  }

  @media print {
    .comp-advertencia {
      background: none;
      border-width: 1px;
    }
  }
</style>
