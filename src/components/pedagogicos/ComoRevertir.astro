---

<div class="comp-como-revertir" data-component="como-revertir" role="note" aria-label="Cómo revertir">
  <div class="comp-revertir-header">
    <span class="comp-badge comp-badge-orange">↩ Reversión</span>
  </div>
  <div class="comp-revertir-body">
    <slot />
  </div>
</div>

<style>
  .comp-como-revertir {
    border: 1px solid var(--sl-color-orange-300);
    border-left: 4px solid var(--sl-color-orange-500);
    margin: 1.5em 0;
    border-radius: 0 8px 8px 0;
    overflow: hidden;
  }

  :root[data-theme="dark"] .comp-como-revertir,
  :global([data-theme="dark"]) .comp-como-revertir {
    border-color: var(--sl-color-orange-700);
    border-left-color: var(--sl-color-orange-500);
  }

  .comp-revertir-header {
    padding: 0.6em 1.1em;
    background: var(--sl-color-orange-50);
  }

  :root[data-theme="dark"] .comp-revertir-header,
  :global([data-theme="dark"]) .comp-revertir-header {
    background: var(--sl-color-orange-950);
  }

  .comp-badge {
    display: inline-block;
    font-size: 0.75em;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.15em 0.6em;
    border-radius: 3px;
  }

  .comp-badge-orange {
    background: var(--sl-color-orange-200);
    color: var(--sl-color-orange-800);
  }

  :root[data-theme="dark"] .comp-badge-orange,
  :global([data-theme="dark"]) .comp-badge-orange {
    background: var(--sl-color-orange-700);
    color: var(--sl-color-orange-100);
  }

  .comp-revertir-body {
    padding: 0.75em 1.1em;
    font-size: 0.93em;
    color: var(--sl-color-text);
  }

  @media (max-width: 720px) {
    .comp-como-revertir {
      margin-left: 0;
      margin-right: 0;
      border-radius: 0 4px 4px 0;
    }
  }

  @media print {
    .comp-como-revertir {
      border-width: 1px;
    }
    .comp-revertir-header {
      background: none;
    }
  }
</style>
