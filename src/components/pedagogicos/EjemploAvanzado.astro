---
interface Props {
  titulo?: string;
}

const { titulo } = Astro.props;
---

<details class="comp-ejemplo-avanzado" data-component="ejemplo-avanzado">
  <summary class="comp-summary">
    <span class="comp-badge comp-badge-example">Ejemplo avanzado</span>
    {titulo && <span class="comp-titulo">{titulo}</span>}
    <span class="comp-chevron" aria-hidden="true">▸</span>
  </summary>
  <div class="comp-body">
    <slot />
  </div>
</details>

<style>
  .comp-ejemplo-avanzado {
    border: 1px solid var(--sl-color-gray-200);
    margin: 1.5em 0;
    border-radius: 8px;
    overflow: hidden;
  }

  :root[data-theme="dark"] .comp-ejemplo-avanzado,
  :global([data-theme="dark"]) .comp-ejemplo-avanzado {
    border-color: var(--sl-color-gray-700);
  }

  .comp-summary {
    cursor: pointer;
    padding: 0.85em 1.25em;
    background: var(--sl-color-gray-50);
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5em;
    user-select: none;
  }

  .comp-summary::-webkit-details-marker {
    display: none;
  }

  :root[data-theme="dark"] .comp-summary,
  :global([data-theme="dark"]) .comp-summary {
    background: var(--sl-color-gray-900);
  }

  .comp-summary:hover {
    background: var(--sl-color-gray-100);
  }

  :root[data-theme="dark"] .comp-summary:hover,
  :global([data-theme="dark"]) .comp-summary:hover {
    background: var(--sl-color-gray-850);
  }

  .comp-badge {
    display: inline-block;
    font-size: 0.75em;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.15em 0.6em;
    border-radius: 3px;
  }

  .comp-badge-example {
    background: var(--sl-color-purple-200);
    color: var(--sl-color-purple-800);
  }

  :root[data-theme="dark"] .comp-badge-example,
  :global([data-theme="dark"]) .comp-badge-example {
    background: var(--sl-color-purple-700);
    color: var(--sl-color-purple-100);
  }

  .comp-titulo {
    font-size: 0.9em;
    font-weight: 600;
    color: var(--sl-color-text);
  }

  .comp-chevron {
    margin-left: auto;
    font-size: 0.8em;
    transition: transform 0.2s ease;
    color: var(--sl-color-gray-500);
  }

  .comp-ejemplo-avanzado[open] .comp-chevron {
    transform: rotate(90deg);
  }

  .comp-body {
    padding: 1.25em;
    border-top: 1px solid var(--sl-color-gray-200);
  }

  :root[data-theme="dark"] .comp-body,
  :global([data-theme="dark"]) .comp-body {
    border-top-color: var(--sl-color-gray-700);
  }

  @media print {
    .comp-summary {
      background: none;
      padding: 0.5em 0.75em;
    }

    .comp-chevron {
      display: none;
    }
  }
</style>
