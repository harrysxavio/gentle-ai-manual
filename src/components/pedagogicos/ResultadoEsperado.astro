<div class="comp-resultado-esperado" data-component="resultado-esperado" role="note" aria-label="Resultado esperado">
  <div class="comp-badge comp-badge-green">Resultado esperado</div>
  <div class="comp-body">
    <slot />
  </div>
</div>

<style>
  .comp-resultado-esperado {
    background: var(--sl-color-green-25, #f0fdf4);
    border: 1px solid var(--sl-color-green-100, #dcfce7);
    padding: 0.85em 1.1em;
    margin: 1.25em 0;
    border-radius: 8px;
  }

  :root[data-theme="dark"] .comp-resultado-esperado,
  :global([data-theme="dark"]) .comp-resultado-esperado {
    background: rgba(34, 197, 94, 0.05);
    border-color: rgba(34, 197, 94, 0.15);
  }

  .comp-badge {
    display: inline-block;
    font-size: 0.75em;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.15em 0.6em;
    border-radius: 3px;
    margin-bottom: 0.5em;
  }

  .comp-badge-green {
    background: var(--sl-color-green-200);
    color: var(--sl-color-green-800);
  }

  :root[data-theme="dark"] .comp-badge-green,
  :global([data-theme="dark"]) .comp-badge-green {
    background: var(--sl-color-green-700);
    color: var(--sl-color-green-100);
  }

  .comp-body {
    color: var(--sl-color-text);
    font-size: 0.93em;
  }

  @media print {
    .comp-resultado-esperado {
      background: none;
      border: 1px solid var(--sl-color-green-200);
    }
  }
</style>
