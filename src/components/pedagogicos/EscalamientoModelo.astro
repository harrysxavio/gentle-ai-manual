---
interface Props {
  agente: string;
}

const { agente } = Astro.props;
---

<div class="comp-escalamiento" data-component="escalamiento-modelo" role="region" aria-label={`Cadena de escalamiento para ${agente}`}>
  <div class="comp-esc-header">
    <span class="comp-esc-icon" aria-hidden="true">📈</span>
    <span>Escalamiento: <code>{agente}</code></span>
  </div>
  <div class="comp-esc-body">
    <slot />
  </div>
</div>

<style>
  .comp-escalamiento {
    border: 1px solid var(--sl-color-gray-300);
    border-radius: 8px;
    margin: 1.5em 0;
    overflow: hidden;
  }

  :root[data-theme="dark"] .comp-escalamiento,
  :global([data-theme="dark"]) .comp-escalamiento {
    border-color: var(--sl-color-gray-700);
  }

  .comp-esc-header {
    padding: 0.6em 1.1em;
    background: var(--sl-color-gray-50);
    display: flex;
    gap: 0.5em;
    align-items: center;
    font-size: 0.85em;
    font-weight: 600;
    color: var(--sl-color-text);
  }

  :root[data-theme="dark"] .comp-esc-header,
  :global([data-theme="dark"]) .comp-esc-header {
    background: var(--sl-color-gray-900);
  }

  .comp-esc-header code {
    font-size: 0.9em;
    background: var(--sl-color-gray-200);
    padding: 0.1em 0.45em;
    border-radius: 3px;
  }

  :root[data-theme="dark"] .comp-esc-header code,
  :global([data-theme="dark"]) .comp-esc-header code {
    background: var(--sl-color-gray-700);
  }

  .comp-esc-body {
    padding: 0.85em 1.1em;
    font-size: 0.93em;
    line-height: 1.7;
  }

  /* Style numbered list with arrows */
  .comp-esc-body :global(ol) {
    list-style: none;
    counter-reset: esc;
    padding-left: 0;
  }

  .comp-esc-body :global(ol > li) {
    counter-increment: esc;
    padding: 0.5em 0 0.5em 2em;
    position: relative;
    border-bottom: 1px solid var(--sl-color-gray-200);
  }

  .comp-esc-body :global(ol > li:last-child) {
    border-bottom: none;
  }

  :root[data-theme="dark"] .comp-esc-body :global(ol > li),
  :global([data-theme="dark"]) .comp-esc-body :global(ol > li) {
    border-bottom-color: var(--sl-color-gray-800);
  }

  .comp-esc-body :global(ol > li)::before {
    content: counter(esc);
    position: absolute;
    left: 0;
    font-weight: 700;
    color: var(--sl-color-accent);
    background: var(--sl-color-accent-low);
    width: 1.5em;
    height: 1.5em;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8em;
    top: 0.55em;
  }

  @media print {
    .comp-esc-header {
      background: none;
    }
  }
</style>
