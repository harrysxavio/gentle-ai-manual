---
import { stages, modules } from '../../data/curriculum.mjs';
const base = import.meta.env.BASE_URL;
---

<section>
  <h2>📚 Módulos</h2>
  {
    stages.map((stage) => {
      const stageModules = modules.filter((m) => stage.moduleIds.includes(m.id));
      if (stageModules.length === 0) return null;
      return (
        <div class="module-index-stage">
          <h3>
            {stage.label} — {stage.question}
          </h3>
          <ul class="module-index-list">
            {
              stageModules.map((mod) => {
                const maxLevel = Math.max(...mod.lessons.map((l) => l.level || 1));
                return (
                  <li class="module-index-item">
                    <a href={base.slice(0, -1) + mod.entry} class="module-index-link" data-module-link>
                      <span class="module-index-num">{mod.id}</span>
                      <span>{mod.title}</span>
                      <span class="module-index-meta">
                        <span class={`module-badge level-${maxLevel}`}>
                          Nivel {maxLevel}
                        </span>
                        {' '}{mod.lessons.length} lecciones
                      </span>
                    </a>
                  </li>
                );
              })
            }
          </ul>
        </div>
      );
    })
  }
  <a href={base.slice(0, -1) + "/00-empezar-aqui/02-indice-completo/"} data-complete-index-link>
    Ver índice completo →
  </a>
</section>

<style>
.module-index-stage {
  margin-bottom: 1em;
  padding: 0.75em 1em;
  border: 1px solid var(--sl-color-gray-5);
  border-radius: 8px;
  background: var(--sl-color-gray-6);
}
[data-theme="dark"] .module-index-stage {
  border-color: var(--sl-color-gray-5);
  background: var(--sl-color-black);
}
.module-index-stage h3 {
  font-size: 1.05em;
  font-weight: 600;
  margin: 0 0 0.5em;
  color: var(--sl-color-accent);
}

.module-index-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.module-index-item {
  margin-bottom: 0.15em;
}
.module-index-item:last-child {
  margin-bottom: 0;
}

.module-index-link {
  display: flex;
  gap: 0.5em;
  align-items: baseline;
  padding: 0.35em 0.5em;
  border-radius: 4px;
  text-decoration: none;
  color: var(--sl-color-text);
  transition: background 0.15s;
}
.module-index-link:hover {
  background: var(--sl-color-gray-6);
}
[data-theme="dark"] .module-index-link:hover {
  background: var(--sl-color-gray-5);
}
.module-index-link:focus-visible {
  outline: 2px solid var(--sl-color-accent);
  outline-offset: 2px;
}

.module-index-num {
  font-weight: 700;
  font-family: var(--sl-font-mono, monospace);
  color: var(--sl-color-accent);
  min-width: 2em;
  font-size: 0.9em;
}

.module-index-meta {
  font-size: 0.82em;
  color: var(--sl-color-gray-3);
  margin-left: auto;
  white-space: nowrap;
}

/* Complete-index link at bottom */
a[data-complete-index-link] {
  display: inline-block;
  margin-top: 0.75em;
  font-size: 0.9em;
  font-weight: 600;
  color: var(--sl-color-accent);
}

@media (prefers-reduced-motion: reduce) {
  .module-index-link { transition: none; }
}
</style>
